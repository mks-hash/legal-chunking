{
  "version": 1,
  "patterns": [
    {"section_type": "part", "regex": "^(часть|part|title|titre)\\s+(?P<num>(?:[ivxlcdm\\d]+|первая|вторая|третья|четвертая|четвёртая|пятая|шестая|седьмая|восьмая|девятая|десятая))\\.?\\s*(?P<title>.*)$"},
    {"section_type": "chapter", "regex": "^(глава|chapter|chap\\.?|chapitre|kapitel)\\s+(?P<num>[ivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "section", "regex": "^(раздел|section|sec\\.?|sect\\.?|division|abschnitt)\\s+(?P<num>[ivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "article", "regex": "^(статья|ст\\.?|article|art\\.?|artikel)\\s+(?P<num>\\d+(?:\\.\\d+)*(?:\\s*[–-]\\s*\\d+(?:\\.\\d+)*)?(?:\\s*,\\s*\\d+(?:\\.\\d+)*)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "clause", "regex": "^(пункт|пункты|п\\.?|clause|cl\\.?)\\s+(?P<num>\\d+(?:\\.\\d+)*(?:\\s*[–-]\\s*\\d+(?:\\.\\d+)*)?(?:\\s*,\\s*\\d+(?:\\.\\d+)*)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "paragraph", "regex": "^(параграф|paragraph|para\\.?|§|absatz|alinéa|alinea)\\s+(?P<num>\\d+(?:\\.\\d+)*(?:\\s*[–-]\\s*\\d+(?:\\.\\d+)*)?(?:\\s*,\\s*\\d+(?:\\.\\d+)*)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "schedule", "regex": "^(schedule|annex|appendix|exhibit|приложение|прил\\.?|аннекс)\\s*(?:№|No\\.?|N)?\\s*(?P<num>[a-zа-яivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "roman_heading", "regex": "^(?P<num>[IVXLCDM]+)(?:[.)]|\\b)\\s+(?P<title>[^\\n]+)$"},
    {"section_type": "numeric_heading", "regex": "^(?P<num>\\d+(?:\\.\\d+){0,5})[.)]?\\s+(?P<title>[A-Za-zА-Яа-яЁё].+)$"}
  ]
}
