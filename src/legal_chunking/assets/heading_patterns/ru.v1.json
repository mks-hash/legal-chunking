{
  "version": 1,
  "patterns": [
    {"section_type": "part", "regex": "^(褔邪褋褌褜|part)\\s+(?P<num>(?:[ivxlcdm\\d]+|锌械褉胁邪褟|胁褌芯褉邪褟|褌褉械褌褜褟|褔械褌胁械褉褌邪褟|褔械褌胁褢褉褌邪褟))\\.?\\s*(?P<title>.*)$"},
    {"section_type": "chapter", "regex": "^(谐谢邪胁邪|chapter|chap\\.?)\\s+(?P<num>[ivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "section", "regex": "^(褉邪蟹写械谢|section|sec\\.?)\\s+(?P<num>[ivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "article", "regex": "^(褋褌邪褌褜褟|褋褌\\.?|article|art\\.?)\\s+(?P<num>\\d+(?:\\.\\d+)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "clause", "regex": "^(锌褍薪泻褌|锌\\.?|clause|cl\\.?)\\s+(?P<num>\\d+(?:\\.\\d+)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "paragraph", "regex": "^(锌邪褉邪谐褉邪褎|paragraph|para\\.?|搂)\\s+(?P<num>\\d+(?:\\.\\d+)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "numeric_heading", "regex": "^(?P<num>\\d+(?:\\.\\d+){0,5})[.)]?\\s+(?P<title>[A-Za-z袗-携邪-褟衼褢].+)$"}
  ]
}
