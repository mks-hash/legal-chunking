{
  "version": 1,
  "patterns": [
    {"section_type": "part", "regex": "^(—á–į—Ā—ā—Ć|part)\\s+(?P<num>(?:[ivxlcdm\\d]+|–Ņ–Ķ—Ä–≤–į—Ź|–≤—ā–ĺ—Ä–į—Ź|—ā—Ä–Ķ—ā—Ć—Ź|—á–Ķ—ā–≤–Ķ—Ä—ā–į—Ź|—á–Ķ—ā–≤—Ď—Ä—ā–į—Ź))\\.?\\s*(?P<title>.*)$"},
    {"section_type": "chapter", "regex": "^(–≥–Ľ–į–≤–į|chapter|chap\\.?)\\s+(?P<num>[ivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "section", "regex": "^(—Ä–į–∑–ī–Ķ–Ľ|section|sec\\.?)\\s+(?P<num>[ivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "article", "regex": "^(—Ā—ā–į—ā—Ć—Ź|—Ā—ā\\.?|article|art\\.?)\\s+(?P<num>\\d+(?:\\.\\d+)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "clause", "regex": "^(–Ņ—É–Ĺ–ļ—ā|–Ņ\\.?|clause|cl\\.?)\\s+(?P<num>\\d+(?:\\.\\d+)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "paragraph", "regex": "^(–Ņ–į—Ä–į–≥—Ä–į—Ą|paragraph|para\\.?|¬ß)\\s+(?P<num>\\d+(?:\\.\\d+)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "schedule", "regex": "^(schedule|annex|appendix|exhibit|–Ņ—Ä–ł–Ľ–ĺ–∂–Ķ–Ĺ–ł–Ķ|–Ņ—Ä–ł–Ľ\\.?)\\s*(?:‚ĄĖ|N|No\\.?)?\\s*(?P<num>[a-z–į-—Źivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "numeric_heading", "regex": "^(?P<num>\\d+(?:\\.\\d+){0,5})[.)]?\\s+(?P<title>[A-Za-z–ź-–Į–į-—Ź–Ā—Ď].+)$"}
  ]
}
