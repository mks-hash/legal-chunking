{
  "version": 1,
  "patterns": [
    {"section_type": "part", "regex": "^(part|title)\\s+(?P<num>[ivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "chapter", "regex": "^(chapter|chap\\.?)\\s+(?P<num>[ivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "section", "regex": "^(section|sec\\.?|§)\\s+(?P<num>[ivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "article", "regex": "^(article|art\\.?)\\s+(?P<num>\\d+(?:\\.\\d+)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "numeric_heading", "regex": "^(?P<num>\\d+(?:\\.\\d+){0,5})[.)]?\\s+(?P<title>[A-Za-z].+)$"}
  ]
}
