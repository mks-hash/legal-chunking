{
  "version": 1,
  "patterns": [
    {"section_type": "part", "regex": "^(part|title|titre)\\s+(?P<num>(?:[ivxlcdm\\d]+|first|second|third|fourth|fifth|sixth|seventh|eighth|ninth|tenth))\\.?\\s*(?P<title>.*)$"},
    {"section_type": "chapter", "regex": "^(chapter|chap\\.?|chapitre|kapitel)\\s+(?P<num>[ivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "section", "regex": "^(section|sec\\.?|sect\\.?|division|abschnitt)\\s+(?P<num>[ivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "article", "regex": "^(article|art\\.?|artikel)\\s+(?P<num>\\d+(?:\\.\\d+)*(?:\\s*[–-]\\s*\\d+(?:\\.\\d+)*)?(?:\\s*,\\s*\\d+(?:\\.\\d+)*)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "clause", "regex": "^(clause|cl\\.?)\\s+(?P<num>\\d+(?:\\.\\d+)*(?:\\s*[–-]\\s*\\d+(?:\\.\\d+)*)?(?:\\s*,\\s*\\d+(?:\\.\\d+)*)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "paragraph", "regex": "^(paragraph|para\\.?|§|absatz|alinéa|alinea)\\s+(?P<num>\\d+(?:\\.\\d+)*(?:\\s*[–-]\\s*\\d+(?:\\.\\d+)*)?(?:\\s*,\\s*\\d+(?:\\.\\d+)*)*)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "schedule", "regex": "^(schedule|annex|appendix|exhibit|аннекс)\\s*(?:№|No\\.?|N)?\\s*(?P<num>[a-zа-яivxlcdm\\d]+)\\.?\\s*(?P<title>.*)$"},
    {"section_type": "roman_heading", "regex": "^(?P<num>[IVXLCDM]+)(?:[.)]|\\b)\\s+(?P<title>[^\\n]+)$"},
    {"section_type": "numeric_heading", "regex": "^(?P<num>\\d+(?:\\.\\d+){0,5})[.)]?\\s+(?P<title>[A-Za-z].+)$"}
  ]
}
